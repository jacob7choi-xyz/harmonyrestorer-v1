# HarmonyRestorer Configuration
# Copy to .env and customize as needed.

# --- Directories ---
# UPLOAD_DIR=/path/to/uploads
# PROCESSED_DIR=/path/to/processed

# --- Audio ---
# UVR_MODEL_NAME=UVR-DeNoise.pth

# --- Security ---
# MAX_UPLOAD_BYTES=52428800          # 50 MB
# RATE_LIMIT_MAX_REQUESTS=10
# RATE_LIMIT_WINDOW_SECONDS=60
# CORS_ORIGINS=http://localhost:3000  # comma-separated
#
# Trusted proxy source IPs for Uvicorn forwarded-header parsing.
# Local direct runs without a reverse proxy: use 127.0.0.1 (the default).
# Docker Compose: set to the pinned app_net subnet in docker-compose.yml.
# Cloud Run / other platforms: set to the platform's internal proxy CIDR.
# FORWARDED_ALLOW_IPS=172.28.0.0/16

# --- Job Lifecycle ---
# JOB_TTL_SECONDS=3600               # 1 hour
# CLEANUP_INTERVAL_SECONDS=300       # 5 minutes

# --- Server ---
# LOG_LEVEL=INFO
